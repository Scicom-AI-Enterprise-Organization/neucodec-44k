# Copy to .env and fill in. .env is gitignored and rsync'd to the pod.
# Format must stay valid for both `source .env` (bash) and the simple k=v
# loader in runpod/launch_pod.py: one KEY=value per line, no spaces around `=`.

# --- required -------------------------------------------------------------- #

# RunPod REST API key — provision/manage the H100 pod (runpod/launch_pod.py).
RUNPOD_API_KEY=

# Hugging Face token — auth for every dataset download + HF push/pull
# (prepare_data.py, push_to_hf.py, local_infer.py, redeploy_scale44k.sh).
HF_TOKEN=

# --- optional -------------------------------------------------------------- #

# Weights & Biases API key — enables wandb logging during training.
# If unset, run_44k_finetune.sh skips `wandb login` and training continues.
WANDB_API_KEY=

# GitHub token — installs the faster Scicom UTMOSv2 fork in the MOS venv
# (runpod/bootstrap.sh). If unset, falls back to public sarulab-speech/UTMOSv2.
GITHUB_TOKEN=

# --- overrides (have working defaults; leave blank unless you need them) ---- #

# RunPod REST base URL (default: https://rest.runpod.io/v1).
RUNPOD_API_BASE=

# Pod base image (default: runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404).
RUNPOD_IMAGE=
